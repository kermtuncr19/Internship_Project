@model Entities.Models.Coupon
@{
    ViewData["Title"] = "Kupon Düzenle";

    var usagePct = Model.UsageLimit.HasValue && Model.UsageLimit > 0
        ? (double)Model.UsedCount / Model.UsageLimit.Value * 100
        : 0;
    var usageDanger = usagePct >= 90;
}

<style>
    :root {
        --fb-navy: #003580;
        --fb-yellow: #ffea00;
        --fb-dark: #0a1628;
        --fb-card: #ffffff;
        --fb-border: #e8edf5;
        --fb-muted: #6b7a99;
        --fb-radius: 14px;
        --fb-shadow: 0 2px 16px rgba(0,53,128,.10);
    }

    .form-page-header {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .form-page-header .back-btn {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .45rem .9rem;
        background: #f1f5fb;
        border: 1px solid var(--fb-border);
        border-radius: 9px;
        font-size: .82rem;
        font-weight: 700;
        color: var(--fb-navy);
        text-decoration: none;
        transition: all .15s;
    }
    .form-page-header .back-btn:hover {
        background: var(--fb-navy); color: #fff; border-color: var(--fb-navy);
    }

    .form-page-header h2 {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--fb-dark);
        letter-spacing: -0.02em;
        margin: 0;
    }

    /* Usage Banner */
    .usage-banner {
        border-radius: 12px;
        border: 1.5px solid var(--fb-border);
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        background: #f9fafb;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .usage-banner-left { display: flex; align-items: center; gap: .75rem; }
    .usage-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, var(--fb-dark), var(--fb-navy));
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .usage-info label {
        font-size: .68rem; font-weight: 800; letter-spacing: .06em;
        text-transform: uppercase; color: var(--fb-muted); display: block; margin-bottom: .2rem;
    }

    .usage-numbers {
        font-size: 1rem; font-weight: 800; color: var(--fb-dark);
    }
    .usage-numbers span { font-size: .8rem; font-weight: 500; color: var(--fb-muted); }

    .usage-bar-section { min-width: 160px; flex: 1; max-width: 260px; }
    .usage-bar-label {
        display: flex; justify-content: space-between;
        font-size: .72rem; font-weight: 600; color: var(--fb-muted); margin-bottom: .35rem;
    }
    .usage-bar-bg {
        height: 7px; border-radius: 99px; background: #e5e7eb; overflow: hidden;
    }
    .usage-bar-fill {
        height: 100%; border-radius: 99px;
        background: linear-gradient(90deg, var(--fb-navy), #4f87e0);
        transition: width .5s ease;
    }
    .usage-bar-fill.danger { background: linear-gradient(90deg, #ef4444, #f97316); }

    /* Form Card */
    .coupon-form-card {
        background: var(--fb-card);
        border-radius: var(--fb-radius);
        box-shadow: var(--fb-shadow);
        border: 1px solid var(--fb-border);
        overflow: hidden;
    }

    .form-card-header {
        background: linear-gradient(135deg, var(--fb-dark) 0%, var(--fb-navy) 100%);
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .form-card-header span {
        color: rgba(255,255,255,.75);
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .form-card-header .dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--fb-yellow); flex-shrink: 0;
    }

    .form-card-header .code-pill {
        margin-left: auto;
        font-family: 'Courier New', monospace;
        font-size: .82rem;
        font-weight: 800;
        color: var(--fb-yellow);
        letter-spacing: .08em;
        background: rgba(255,255,255,.08);
        padding: .2em .7em;
        border-radius: 7px;
        border: 1px solid rgba(255,204,0,.25);
    }

    .form-body { padding: 1.75rem; }

    .form-section-title {
        font-size: .68rem; font-weight: 800; letter-spacing: .1em;
        text-transform: uppercase; color: var(--fb-muted);
        margin-bottom: .9rem; margin-top: 1.5rem;
        padding-bottom: .4rem; border-bottom: 1px solid var(--fb-border);
    }
    .form-section-title:first-child { margin-top: 0; }

    .field-group {
        display: grid; gap: 1rem;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    }
    .field-group.two-col { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }

    .field-wrap { display: flex; flex-direction: column; gap: .4rem; }

    .field-wrap label {
        font-size: .78rem; font-weight: 700; color: #374151; letter-spacing: .01em;
    }

    .field-wrap label .opt-tag {
        font-size: .68rem; font-weight: 600; color: var(--fb-muted);
        background: #f1f5fb; border: 1px solid var(--fb-border);
        padding: .1em .45em; border-radius: 5px; margin-left: .35rem;
    }

    .field-wrap input[type="text"],
    .field-wrap input[type="number"],
    .field-wrap input[type="datetime-local"] {
        padding: .6rem .9rem;
        border: 1.5px solid var(--fb-border);
        border-radius: 9px;
        font-size: .9rem;
        color: #1e293b;
        background: #fafbfd;
        transition: border-color .15s, box-shadow .15s;
        outline: none;
        width: 100%;
        box-sizing: border-box;
    }

    .field-wrap input:focus {
        border-color: var(--fb-navy);
        box-shadow: 0 0 0 3px rgba(0,53,128,.1);
        background: #fff;
    }

    .field-wrap .text-danger { font-size: .75rem; color: #dc2626; font-weight: 600; }

    /* Toggle */
    .toggle-wrap {
        display: flex; align-items: center; gap: .75rem;
        padding: .75rem 1rem;
        background: #f9fafb;
        border: 1.5px solid var(--fb-border);
        border-radius: 10px;
        cursor: pointer; user-select: none;
        transition: border-color .15s;
        margin-top: .3rem;
    }
    .toggle-wrap:hover { border-color: var(--fb-navy); }

    .toggle-switch {
        width: 40px; height: 22px;
        background: #d1d5db; border-radius: 99px;
        position: relative; flex-shrink: 0; transition: background .2s;
    }
    .toggle-switch::after {
        content: '';
        width: 16px; height: 16px;
        background: #fff; border-radius: 50%;
        position: absolute; top: 3px; left: 3px;
        transition: transform .2s;
        box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }
    .toggle-switch.on { background: var(--fb-navy); }
    .toggle-switch.on::after { transform: translateX(18px); }

    .toggle-label { font-size: .88rem; font-weight: 600; color: #374151; }
    input#IsActive { display: none; }

    /* Footer */
    .form-footer {
        padding: 1.25rem 1.75rem;
        background: #f8fafd;
        border-top: 1px solid var(--fb-border);
        display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    }

    .btn-save {
        background: linear-gradient(135deg, var(--fb-navy) 0%, #1a4fa0 100%);
        color: #fff; border: none;
        padding: .65rem 1.6rem;
        border-radius: 10px; font-weight: 700; font-size: .9rem;
        cursor: pointer;
        display: inline-flex; align-items: center; gap: .4rem;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(0,53,128,.25);
    }
    .btn-save:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(0,53,128,.35);
        color: var(--fb-yellow);
    }

    .btn-cancel {
        background: transparent; color: var(--fb-muted);
        border: 1.5px solid var(--fb-border);
        padding: .65rem 1.4rem; border-radius: 10px;
        font-weight: 700; font-size: .9rem;
        text-decoration: none;
        display: inline-flex; align-items: center; gap: .4rem;
        transition: all .15s;
    }
    .btn-cancel:hover { border-color: #94a3b8; color: #374151; background: #f1f5fb; }

    @@media (max-width: 576px) {
        .form-body { padding: 1.2rem; }
        .form-footer { padding: 1rem 1.2rem; }
        .field-group { grid-template-columns: 1fr; }
        .field-group.two-col { grid-template-columns: 1fr; }
        .usage-bar-section { min-width: 100%; max-width: 100%; }
        .usage-banner { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="form-page-header">
    <a class="back-btn" asp-area="Admin" asp-controller="Coupon" asp-action="Index">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Geri
    </a>
    <h2>Kupon Düzenle</h2>
</div>

<!-- Usage Banner -->
<div class="usage-banner">
    <div class="usage-banner-left">
        <div class="usage-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                <path d="M21 5H3a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1Z"/>
                <path d="M12 5v14M3 12h18"/>
            </svg>
        </div>
        <div class="usage-info">
            <label>Toplam Kullanım</label>
            <div class="usage-numbers">
                @Model.UsedCount
                @if (Model.UsageLimit.HasValue)
                {
                    <span> / @Model.UsageLimit kez</span>
                }
                else
                {
                    <span> kez (limitsiz)</span>
                }
            </div>
        </div>
    </div>

    @if (Model.UsageLimit.HasValue)
    {
        <div class="usage-bar-section">
            <div class="usage-bar-label">
                <span>Kullanım Oranı</span>
                <span>%@usagePct.ToString("0.#")</span>
            </div>
            <div class="usage-bar-bg">
                <div class="usage-bar-fill @(usageDanger ? "danger" : "")"
                     style="width:@(Math.Min(usagePct, 100))%"></div>
            </div>
        </div>
    }
</div>

<div class="coupon-form-card">
    <div class="form-card-header">
        <div class="dot"></div>
        <span>Kupon Bilgileri</span>
        <span class="code-pill">@Model.Code</span>
    </div>

    <form method="post">
        @Html.AntiForgeryToken()

        <div class="form-body">
            <!-- Temel Bilgiler -->
            <div class="form-section-title">Temel Bilgiler</div>
            <div class="field-group">
                <div class="field-wrap">
                    <label>Kod</label>
                    <input asp-for="Code" type="text" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="field-wrap">
                    <label>İndirim %</label>
                    <input asp-for="Percent" type="number" step="0.01" min="0" max="100" />
                    <span asp-validation-for="Percent" class="text-danger"></span>
                </div>

                <div class="field-wrap">
                    <label>Min Sepet Tutarı <span class="opt-tag">opsiyonel</span></label>
                    <input asp-for="MinCartTotal" type="number" step="0.01" min="0" />
                    <span asp-validation-for="MinCartTotal" class="text-danger"></span>
                </div>

                <div class="field-wrap">
                    <label>Kullanım Limiti <span class="opt-tag">opsiyonel</span></label>
                    <input asp-for="UsageLimit" type="number" min="1" />
                    <span asp-validation-for="UsageLimit" class="text-danger"></span>
                </div>
            </div>

            <!-- Geçerlilik -->
            <div class="form-section-title">Geçerlilik Tarihleri</div>
            <div class="field-group two-col">
                <div class="field-wrap">
                    <label>Başlangıç (UTC) <span class="opt-tag">opsiyonel</span></label>
                    <input name="StartsAtUtc" type="datetime-local"
                           value="@(Model.StartsAtUtc.HasValue ? Model.StartsAtUtc.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                    <span asp-validation-for="StartsAtUtc" class="text-danger"></span>
                </div>

                <div class="field-wrap">
                    <label>Bitiş (UTC) <span class="opt-tag">opsiyonel</span></label>
                    <input name="EndsAtUtc" type="datetime-local"
                           value="@(Model.EndsAtUtc.HasValue ? Model.EndsAtUtc.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                    <span asp-validation-for="EndsAtUtc" class="text-danger"></span>
                </div>
            </div>

            <!-- Durum -->
            <div class="form-section-title">Durum</div>
            <input asp-for="IsActive" id="IsActive" />
            <label class="toggle-wrap" for="IsActive">
                <div class="toggle-switch" id="toggleSwitch"></div>
                <span class="toggle-label" id="toggleLabel">
                    @(Model.IsActive ? "Aktif" : "Pasif")
                </span>
            </label>
        </div>

        <div class="form-footer">
            <button type="submit" class="btn-save">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                Güncelle
            </button>
            <a class="btn-cancel" asp-area="Admin" asp-controller="Coupon" asp-action="Index">
                Vazgeç
            </a>
        </div>
    </form>
</div>

<script>
    const checkbox = document.getElementById('IsActive');
    const sw = document.getElementById('toggleSwitch');
    const lbl = document.getElementById('toggleLabel');

    function syncToggle() {
        if (checkbox.checked) {
            sw.classList.add('on');
            lbl.textContent = 'Aktif';
            lbl.style.color = '#003580';
        } else {
            sw.classList.remove('on');
            lbl.textContent = 'Pasif';
            lbl.style.color = '#94a3b8';
        }
    }

    checkbox.addEventListener('change', syncToggle);
    syncToggle();
</script>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
